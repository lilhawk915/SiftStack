{
    "actorSpecification": 1,
    "name": "siftstack-ohio-orchestrator",
    "title": "SiftStack Ohio Orchestrator",
    "description": "Daily/weekly/quarterly foreclosure + probate + tax_delinquent + sheriff_sale scrape across 7 SW Ohio counties (Butler, Clark, Clermont, Greene, Miami, Montgomery, Warren). Enriches via OnBase PDF Vision (probate phones), Tracerfy (skip trace) + Trestle (phone scoring) for non-probate rows, then writes a DataSift-formatted CSV and posts to #h3-homebuyers-ftm.",
    "version": "2.0",
    "buildTag": "latest",
    "input": "./input_schema.json",
    "dockerfile": "../Dockerfile",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "title": "SiftStack Ohio Records",
            "views": {
                "overview": {
                    "title": "Overview",
                    "transformation": {
                        "fields": [
                            "date_added",
                            "case_number",
                            "notice_type",
                            "county",
                            "address",
                            "city",
                            "state",
                            "zip",
                            "owner_name",
                            "primary_phone",
                            "primary_phone_tier",
                            "source_url"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "date_added": { "label": "Date", "format": "text" },
                            "case_number": { "label": "Case #", "format": "text" },
                            "notice_type": { "label": "Type", "format": "text" },
                            "county": { "label": "County", "format": "text" },
                            "address": { "label": "Address", "format": "text" },
                            "owner_name": { "label": "Owner", "format": "text" },
                            "primary_phone": { "label": "Phone 1", "format": "text" },
                            "primary_phone_tier": { "label": "Tier", "format": "text" }
                        }
                    }
                }
            }
        }
    }
}
